# Copy to docker/.env and customize (optional — compose has sensible defaults)
# cp docker/.env.example docker/.env

# Worker
PLAYWRIGHT_HEADLESS=true
WORKER_CONCURRENCY=1
MAX_APPLICATIONS_PER_RUN=50
GEMINI_API_KEY=

# First-time Naukri login in Docker: pnpm docker:up:headed → http://localhost:6080/vnc.html
# Or run worker locally with PLAYWRIGHT_HEADLESS=false; sessions reuse via worker/sessions volume.
NAUKRI_RESUME_PATH=./assets/Sumit-Raj-Resume.pdf
PROFILE_DATA_PATH=./profile_data.json

# Backend
JWT_SECRET=dev-docker-secret-change-me
OPENAI_API_KEY=
