{
  "name": "@aiapply/extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "AI Job Apply Agent",
  "description": "Browser extension for AI-assisted job applications",
  "plasmo": {
    "src": "."
  },
  "scripts": {
    "dev": "node ./scripts/print-load-hint.js && pnpm exec plasmo dev",
    "build": "pnpm exec plasmo build",
    "package": "pnpm exec plasmo package",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint: extension\""
  },
  "dependencies": {
    "@aiapply/shared": "workspace:*",
    "plasmo": "^0.89.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "permissions": ["storage", "tabs", "activeTab"],
    "host_permissions": [
      "https://*.naukri.com/*",
      "https://*.linkedin.com/*",
      "https://*.indeed.com/*",
      "http://localhost:3001/*",
      "http://127.0.0.1:3001/*"
    ]
  }
}
