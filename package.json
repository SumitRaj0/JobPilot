{
  "name": "ai-apply-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI Job Apply Agent — monorepo",
  "scripts": {
    "dev:extension": "pnpm --filter @aiapply/extension dev",
    "dev:backend": "pnpm --filter @aiapply/backend dev",
    "dev:worker": "pnpm --filter @aiapply/worker dev",
    "test:linkedin": "pnpm --filter @aiapply/worker test:linkedin",
    "dev:dashboard": "pnpm --filter @aiapply/dashboard dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose up --build",
    "docker:up:detach": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:up:headed": "docker compose -f docker-compose.yml -f docker-compose.headed.yml up --build",
    "docker:up:prod": "docker compose -f docker-compose.prod.yml up --build",
    "docker:up:prod:detach": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:down:prod": "docker compose -f docker-compose.prod.yml down",
    "docker:build:extension": "docker compose -f docker-compose.extension-build.yml run --rm extension-build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
