REDIS_URL=redis://localhost:6379
# Set to 3 to run Naukri + LinkedIn + Indeed in parallel (POST /api/automation/start-all)
WORKER_CONCURRENCY=3
PLAYWRIGHT_HEADLESS=true
SESSION_STORAGE_PATH=./sessions
SCREENSHOT_PATH=./screenshots
NAUKRI_RESUME_PATH=./assets/Sumit-Raj-Resume.pdf
# Caps successful applications per run
MAX_APPLICATIONS_PER_RUN=50
NAUKRI_SCRAPE_LIMIT=60
NAUKRI_SCROLL_ROUNDS=5
MAX_RECOMMENDED_SCROLLS=18
MAX_RECOMMENDED_JOBS=120
RECENT_JOB_DEDUPE_TTL_SEC=86400
# Time to wait for manual login in the Playwright window (each platform once)
NAUKRI_LOGIN_WAIT_MS=180000
# First-time LinkedIn/Indeed: set PLAYWRIGHT_HEADLESS=false and log in when the worker browser opens

# Question resolver (local cache → Gemini free tier → terminal prompt)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
FUZZY_MATCH_THRESHOLD=0.8
PROFILE_DATA_PATH=./profile_data.json
# Log scraped Q&A without filling or submitting
DRY_RUN=false
